
public interface FantasyPlayer {
 
    String getName();
 
    String getSport();
 
    
     // Total cumulative fantasy points earned so far this season.
     // Recalculated from the player's live stats every call.
     
    double getFantasyPoints();
 
    
     //Draft price in fantasy dollars.
   
    int getPrice();
 
 //One-line summary for draft screens
    String getDraftSummary();
}
